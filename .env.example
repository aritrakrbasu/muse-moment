# Muse Moment Environment Variables

# Cloudflare Worker URL (REQUIRED for production)
# Deploy the worker/ folder first, then paste your worker URL below
# All AI logic happens server-side - the API key stays secure
REACT_APP_WORKER_URL=https://muse-moment-gemini-proxy.YOUR_SUBDOMAIN.workers.dev

# Local development only (optional)
# If you want to test without the worker locally, uncomment below:
# REACT_APP_GEMINI_API_KEY=your-gemini-api-key-here
